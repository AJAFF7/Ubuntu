: 1772034713:0;c
: 1772034714:0;# 1. Delete any leftover TUN interfaces\
sudo ip link show | grep tun\
# Suppose it shows tun0 or tun1, delete them:\
sudo ip link set tun0 down\
sudo ip link delete tun0\
\
# 2. Flush old routes\
sudo ip route flush table main\
\
# 3. Re-acquire IP from your Wi-Fi\
sudo dhclient -v wlp1s0f0   # replace wlp1s0f0 with your Wi-Fi interface\
\
# 4. Restart DNS resolver\
sudo systemctl restart systemd-resolved\
\
# 5. Verify your public IP\
curl ifconfig.me
