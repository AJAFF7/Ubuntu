* * * * * sudo sh -c 'echo 2 > /proc/sys/vm/drop_caches && echo "$(date): Cache level 1 dropped successfully" >> /var/log/cleaner/Caches-Cleaner/drop_caches_1.log'\
* * * * * sudo sh -c 'echo 3 > /proc/sys/vm/drop_caches && echo "$(date): Cache level 3 dropped successfully" >> /var/log/cleaner/Caches-Cleaner/drop_caches_1.log'\
\
* * * * * sudo sh -c 'sync; echo 1 > /proc/sys/vm/drop_caches && echo "$(date): Cache level 1 dropped with sync successfully" >> /var/log/cleaner/Caches-Cleaner/drop_caches_2.log'\
* * * * * sudo sh -c 'sync; echo 2 > /proc/sys/vm/drop_caches && echo "$(date): Cache level 3 dropped with sync successfully" >> /var/log/cleaner/Caches-Cleaner/drop_caches_2.log'\
* * * * * sudo sh -c 'sync; echo 3 > /proc/sys/vm/drop_caches && echo "$(date): Cache level 2 dropped with sync successfully" >> /var/log/cleaner/Caches-Cleaner/drop_caches_2.log'\
\
### System Cleaner\
\
* * * * * journalctl --vacuum-time=1w && echo "\e[32mSuccessfully cleaned\e[0m journalctl logs at $(date)" | sudo tee -a /var/log/cleaner/Systems-Cleaner/cron_journalctl.log > /dev/null\
\
* * * * * rm -rf /tmp/* && echo "\e[32mSuccessfully cleaned\e[0m /tmp directory at $(date)" | sudo tee -a /var/log/cleaner/Systems-Cleaner/cron_tmp_clean.log > /dev/null\
\
* * * * * rm -rf ~/.cache/* && echo "\e[32mSuccessfully cleaned\e[0m ~/.cache directory at $(date)" | sudo tee -a /var/log/cleaner/Systems-Cleaner/cron_cache_clean.log > /dev/null\
\
### Apt\
\
* * * * * sudo apt-get clean --dry-run && echo "$(date): Successfully ran 'apt-get clean --dry-run'" >> /var/log/cleaner/Apt-Cleaner/clean_apt.log\
\
* * * * * sudo apt-get autoclean && echo "$(date): Successfully ran 'apt-get autoclean'" >> /var/log/cleaner/Apt-Cleaner/clean_apt.log\
\
* * * * * sudo apt-get autoremove --purge -y && echo "$(date): Successfully ran 'apt-get autoremove'" >> /var/log/cleaner/Apt-Cleaner/clean_apt.log\
\
### Processes\
\
* * * * * /var/log/cleaner/Processes/cleanup.sh\
\
### Update The Systems\
\
* * * * * /var/log/cleaner/Update-Repository/apt_update.sh\

