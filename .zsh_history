/^Nmap/ && !/^Nmap scan report/ {\
    printf "Starting %s\n", $0;  # Print the Nmap version and other starting messages\
    printf "%-20s %-15s %-15s\n", "PORT", "STATE", "SERVICE"; \
    print "----------------------------------"; \
}\
/^Host is up/ {\
    gsub(/\(/, "", $0);  # Remove the opening parenthesis\
    gsub(/\)/, "", $0);  # Remove the closing parenthesis\
    split($0, a, " ");    # Split the line to access words\
    printf "%-10s %-10s\n", a[1], a[2];  # Print "Host" and "Latency"\
    print "----------------------------------"; \
}\
/^PORT/ { \
    next;  # Skip this line, handled above\
}\
!/^PORT/ && NF { \
    printf "%-10s %-15s %-15s\n", $1, $2, $3; \
}\
END {\
    print "\nNmap done: 1 IP address (1 host up) scanned in 0.17 seconds"; \
    print "Nmap done: 1 host scanned in 0.12 seconds"; \
}'\

