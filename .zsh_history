: 1729248357:0;alias nmap="sudo nmap -sn 192.168.1.0/24 | awk ' \
BEGIN {\
    printf \"% -20s %-15s %-15s %-25s %-35s\n\", \"IP Address\", \"Latency\", \"Host Status\", \"MAC Address\", \"Manufacturer\"\
    print \"----------------------------------------------------------------------------------------------------\"\
}\
/Nmap scan report/ {\
    ip = \$5\
}\
/Host is up/ {\
    latency = \$4\
    status = \"Up\"\
    latency = gensub(/\\\(|\\\)/, \"\", \"g\", latency)  # Remove parentheses from latency\
}\
/Host seems down/ {\
    status = \"Down\"\
}\
/MAC Address/ {\
    mac = \$3\
    manufacturer = substr(\$0, index(\$0,\$4))\
    printf \"% -20s %-15s %-15s %-25s %-35s\n\", ip, latency, status, mac, manufacturer\
}'"\

