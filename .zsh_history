: 1772085023:0;# 1. Build the updated API image\
cd /home/dev/SoftMax/blazor-auth-app\
docker build -t ajaff/blazor-api:latest -f BlazorAuthApp.Api/Dockerfile .\
\
# 2. Load the image into your kind cluster\
kind load docker-image ajaff/blazor-api:latest --name cluster-0\
\
# 3. Restart the API pods to use the new image\
kubectl rollout restart deployment blazor-api -n default\
\
# 4. Watch the pods come up\
kubectl get pods -n default -w
