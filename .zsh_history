: 1729334380:0;nano #!/bin/bash\
\
# File to store replica counts\
replica_file="replica_counts.txt"\
\
# Get all namespaces except kube-system\
namespaces=$(kubectl get namespaces --no-headers | awk '{print $1}' | grep -v kube-system)\
\
# Clear the previous replica counts file\
> $replica_file\
\
# Loop through each namespace and scale down deployments and stateful sets\
for ns in $namespaces; do\
  # Scale down all deployments and save the current replicas\
  kubectl get deployment --all -n $ns -o=jsonpath='{range .items[*]}{.metadata.name}{" "}{.spec.replicas}{"\n"}{end}' >> $replica_file\
  kubectl scale --replicas=0 deployment --all -n $ns\
\
  # Scale down all stateful sets and save the current replicas\
  kubectl get statefulset --all -n $ns -o=jsonpath='{range .items[*]}{.metadata.name}{" "}{.spec.replicas}{"\n"}{end}' >> $replica_file\
  kubectl scale --replicas=0 statefulset --all -n $ns\
done\
\
echo "Current replica counts saved to $replica_file."\
c
