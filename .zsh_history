: 1721143694:0;kill #!/bin/bash\
\
while true; do\
  # Play custom notification sound\
  /usr/bin/paplay /usr/share/sounds/freedesktop/stereo/complete.oga &\
\
  # Send the notification with a 10-second timeout\
  notify-send -t 10000 -i info "Backup Time" "It's time to backup your files."\
\
  sleep 300 # Sleep for 300 seconds (5 minutes)\
done\

