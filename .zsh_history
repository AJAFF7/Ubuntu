: 1772035845:0;c
: 1772035845:0;# Delete the old VPN profile\
nmcli connection delete id "VPN 1"\
\
# Flush any leftover routes\
sudo ip route flush table main\
\
# Restart your Wi-Fi interface to get normal routing\
sudo dhclient -v wlp1s0f0\
\
# Restart DNS\
sudo systemctl restart systemd-resolved
